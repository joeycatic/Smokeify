BLOOMTECH_PASSWORD=
# Override form field names if needed (defaults: email/password)
BLOOMTECH_EMAIL_FIELD=
BLOOMTECH_PASSWORD_FIELD=
# Optional: submit button name/value (defaults: login=1)
BLOOMTECH_LOGIN_SUBMIT_FIELD=
BLOOMTECH_LOGIN_SUBMIT_VALUE=
