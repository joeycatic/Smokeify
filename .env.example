# Core app
DATABASE_URL=
NEXTAUTH_URL=
NEXTAUTH_SECRET=
MAINTENANCE_MODE=

# Admin security
# Admin workspace re-auth TTL in minutes.
ADMIN_REAUTH_TTL_MINUTES=120
# Optional: accepted authenticator clock drift in 30-second steps.
ADMIN_TOTP_WINDOW_STEPS=1
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Checkout and payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
MOBILE_PREMIUM_PRICE_MONTHLY_ID=
MOBILE_PREMIUM_PRICE_YEARLY_ID=
MOBILE_STRIPE_RETURN_URL=smokeify://premium-return
# Optional: explicit Stripe Checkout payment methods (comma-separated).
# Keep in sync with NEXT_PUBLIC_PAYMENT_METHOD_LOGOS to avoid policy mismatch.
# Supported here: card,paypal,klarna
STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES=
CHECKOUT_RECOVERY_DELAY_MINUTES=60
CHECKOUT_RECOVERY_BATCH_SIZE=50

# Account and token security
# Required for production mobile token signing. Falls back to NEXTAUTH_SECRET if unset.
MOBILE_API_TOKEN_SECRET=
INVOICE_DOWNLOAD_SECRET=
ORDER_VIEW_LINK_SECRET=
# Required for Discord account-link token signing. Must match the bot's SMOKEIFY_LINK_TOKEN_SECRET.
SMOKEIFY_LINK_TOKEN_SECRET=
# Required for bot-side live order lookups. Must match the bot's SMOKEIFY_API_KEY.
DISCORD_BOT_API_KEY=

# Loyalty and incentives
LOYALTY_POINTS_PER_EUR=1
REVIEW_INCENTIVE_PERCENT_OFF=5

# Public app and storefront routing
NEXT_PUBLIC_APP_URL=https://www.smokeify.de
NEXT_PUBLIC_GROW_APP_URL=
NEXT_PUBLIC_SMOKEIFY_APP_URL=
# Optional comma-separated hostnames used to classify order source website.
# Example: MAIN_STOREFRONT_HOSTS=www.smokeify.de,smokeify.de
MAIN_STOREFRONT_HOSTS=
# Example: GROW_STOREFRONT_HOSTS=www.growvault.de,growvault.de
GROW_STOREFRONT_HOSTS=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=
NEXT_PUBLIC_DISCORD_URL=
CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_PAYMENT_METHOD_LOGOS=card,apple_pay,google_pay
NEXT_PUBLIC_NEWSLETTER_OFFER_ACTIVE_UNTIL=

# Email and messaging
RESEND_API_KEY=
RESEND_FROM_EMAIL=
EMAIL_SERVER=
EMAIL_FROM=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI
OPENAI_API_KEY=
AI_MODEL_FAST=gpt-4o-mini
AI_MODEL_STRONG=gpt-4o
AI_ANALYZER_ESCALATION_CONFIDENCE=0.72

# Jobs and operations
CRON_SECRET=
# Pricing automation
PRICING_AUTOMATION_ENABLED=true
PRICING_AUTOMATION_CURRENCY=EUR
PRICING_AUTOMATION_WINDOW_DAYS=30
PRICING_AUTOMATION_MAX_AUTO_MOVE_BPS=500
PRICING_AUTOMATION_MIN_PRODUCT_AGE_DAYS=14
PRICING_AUTOMATION_COMPETITOR_MAX_AGE_HOURS=72
PRICING_AUTOMATION_COMPETITOR_MIN_RELIABILITY=0.6
PRICING_AUTOMATION_LOW_DATA_MIN_VIEWS=50
PRICING_AUTOMATION_LOW_DATA_MIN_UNITS_SOLD=2
PRICING_AUTOMATION_WEAK_CONVERSION_RATE=0.012
PRICING_AUTOMATION_STRONG_CONVERSION_RATE=0.035
PRICING_AUTOMATION_WEAK_SALES_VELOCITY=0.05
PRICING_AUTOMATION_STRONG_SALES_VELOCITY=0.35
PRICING_AUTOMATION_HIGH_STOCK_COVER_DAYS=60
PRICING_AUTOMATION_LOW_STOCK_COVER_DAYS=14
PRICING_AUTOMATION_PAYMENT_FEE_PERCENT_BPS=150
PRICING_AUTOMATION_PAYMENT_FIXED_FEE_CENTS=25
PRICING_AUTOMATION_RETURN_BUFFER_BPS=300
PRICING_AUTOMATION_TARGET_MARGIN_BPS=2500
# Shared template for bulk pricing-profile seeding
PRICING_PROFILE_SUPPLIER_SHIPPING_CENTS=
PRICING_PROFILE_INBOUND_SHIPPING_CENTS=
PRICING_PROFILE_PACKAGING_CENTS=
PRICING_PROFILE_HANDLING_CENTS=
PRICING_PROFILE_PAYMENT_FEE_PERCENT_BPS=150
PRICING_PROFILE_PAYMENT_FIXED_FEE_CENTS=25
PRICING_PROFILE_RETURN_BUFFER_BPS=300
PRICING_PROFILE_TARGET_MARGIN_BPS=2500
PRICING_PROFILE_SEGMENT=CORE
PRICING_PROFILE_AUTO_REPRICE_ENABLED=true
PRICING_PROFILE_COMPETITOR_RELIABILITY=0.65
PRICING_PROFILE_COMPETITOR_SOURCE_LABEL=Bloomtech guest price
PRICING_PROFILE_SEED_ALLOW_WRITE=
SUPPLIER_SYNC_MAX_MS=
# Set to 0 or leave empty to disable the runtime limit.
SUPPLIER_SYNC_MAX_PRODUCTS=
SUPPLIER_SYNC_DELAY_MS=
SUPPLIER_SYNC_PAGE_SIZE=
# Optional: resume after a specific product id (for sharded cron runs).
SUPPLIER_SYNC_START_AFTER_ID=

# Bloomtech supplier sync
BLOOMTECH_LOGIN_URL=
BLOOMTECH_EMAIL=
BLOOMTECH_PASSWORD=
# Override form field names if needed (defaults: email/password)
BLOOMTECH_EMAIL_FIELD=
BLOOMTECH_PASSWORD_FIELD=
# Optional: submit button name/value (defaults: login=1)
BLOOMTECH_LOGIN_SUBMIT_FIELD=
BLOOMTECH_LOGIN_SUBMIT_VALUE=
# Optional: provide a raw cookie string from your browser session
BLOOMTECH_COOKIE=
BLOOMTECH_TARGET_MARGIN_PERCENT=20
BLOOMTECH_TARGET_MARGIN_PERCENT_BELOW_THRESHOLD=20
BLOOMTECH_TARGET_MARGIN_PERCENT_ABOVE_THRESHOLD=20
BLOOMTECH_MARGIN_THRESHOLD_EUR=100
# Options: 99, none
BLOOMTECH_PRICE_ROUNDING=99
BLOOMTECH_MIN_PRICE_EUR=10
# Required for bloomtech:override-pricing writes (preview is always allowed)
BLOOMTECH_REPRICE_ALLOW_WRITE=

# B2B Headshop supplier sync
B2B_HEADSHOP_SUPPLIER_ID=
B2B_HEADSHOP_SUPPLIER_NAME=
B2B_HEADSHOP_SELLER_NAME=B2B Headshop
B2B_HEADSHOP_SELLER_URL=https://b2b-headshop.de
B2B_HEADSHOP_LOGIN_URL=https://b2b-headshop.de/Konto
B2B_HEADSHOP_EMAIL=
B2B_HEADSHOP_PASSWORD=
# Override form field names if needed (defaults: email/passwort)
B2B_HEADSHOP_EMAIL_FIELD=
B2B_HEADSHOP_PASSWORD_FIELD=
# Optional: submit button name/value (defaults: login=1)
B2B_HEADSHOP_LOGIN_SUBMIT_FIELD=
B2B_HEADSHOP_LOGIN_SUBMIT_VALUE=
# Optional: provide a raw cookie string from your browser session
B2B_HEADSHOP_COOKIE=
B2B_HEADSHOP_DEBUG=
B2B_HEADSHOP_TARGET_MARGIN_PERCENT=20
B2B_HEADSHOP_TARGET_MARGIN_PERCENT_BELOW_THRESHOLD=20
B2B_HEADSHOP_TARGET_MARGIN_PERCENT_ABOVE_THRESHOLD=20
B2B_HEADSHOP_MARGIN_THRESHOLD_EUR=100
# Options: 99, none
B2B_HEADSHOP_PRICE_ROUNDING=99
B2B_HEADSHOP_MIN_PRICE_EUR=10
# Required for b2b-headshop:override-pricing writes (preview is always allowed)
B2B_HEADSHOP_REPRICE_ALLOW_WRITE=

# Catalog repricing
# Global catalog repricing (all ACTIVE products)
CATALOG_TARGET_MARGIN_PERCENT=20
CATALOG_TARGET_MARGIN_PERCENT_BELOW_THRESHOLD=20
CATALOG_TARGET_MARGIN_PERCENT_ABOVE_THRESHOLD=20
CATALOG_MARGIN_THRESHOLD_EUR=100
# Options: 99, none
CATALOG_PRICE_ROUNDING=99
CATALOG_MIN_PRICE_EUR=10
