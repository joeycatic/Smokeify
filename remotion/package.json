{
  "name": "smokeify-remotion",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.tsx --port=3901",
    "render": "remotion render src/index.tsx ProductShowcase out/product-showcase.mp4",
    "render:gif": "remotion render src/index.tsx ProductShowcase --codec=gif out/product-showcase.gif",
    "render:banner": "remotion render src/index.tsx HeroBanner --codec=h264 --crf=18 --timeout=180000 out/banner.mp4",
    "render:banner:webm": "remotion render src/index.tsx HeroBanner --codec=vp8 --crf=20 --timeout=180000 out/banner.webm",
    "render:banner:mobile": "remotion render src/index.tsx HeroBannerMobile --codec=h264 --crf=28 --timeout=180000 out/banner-mobile.mp4",
    "render:banner:mobile:webm": "remotion render src/index.tsx HeroBannerMobile --codec=vp8 --crf=32 --timeout=180000 out/banner-mobile.webm",
    "render:banner:poster": "remotion still src/index.tsx HeroBanner --frame=160 out/banner-poster.png",
    "render:banner:hq": "remotion render src/index.tsx HeroBannerHQ --codec=h264 --crf=14 --pixel-format=yuv420p --timeout=240000 out/banner-hq.mp4",
    "render:banner:hq:webm": "remotion render src/index.tsx HeroBannerHQ --codec=vp9 --crf=16 --timeout=240000 out/banner-hq.webm"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.0.0"
  }
}
